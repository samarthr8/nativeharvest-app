# ===========================================
# NativeHarvest - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --------------- Database ---------------
DB_HOST=postgres
DB_PORT=5432
DB_USER=nhuser
DB_PASSWORD=                # REQUIRED - set a strong password
DB_NAME=nativeharvest

# --------------- Admin Auth ---------------
ADMIN_EMAIL=                # REQUIRED - admin login email
ADMIN_PASSWORD=             # REQUIRED - admin login password (use a strong password)
JWT_SECRET=                 # REQUIRED - random string for JWT signing (e.g. openssl rand -hex 32)

# --------------- AWS S3 ---------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=          # REQUIRED for image uploads
AWS_SECRET_ACCESS_KEY=      # REQUIRED for image uploads
S3_BUCKET_NAME=nativeharvest-images

# --------------- Razorpay ---------------
RAZORPAY_KEY_ID=            # REQUIRED for payments
RAZORPAY_KEY_SECRET=        # REQUIRED for payments
RAZORPAY_WEBHOOK_SECRET=    # REQUIRED for payment webhooks

# --------------- Email (SMTP) ---------------
EMAIL_USER=                 # REQUIRED for order confirmation emails
EMAIL_PASS=                 # REQUIRED - app password, not account password

# --------------- App ---------------
NODE_ENV=development
PORT=5000
CORS_ORIGINS=https://nativeharvest.store,https://www.nativeharvest.store  # comma-separated allowed origins
